@model Product

<div>
    <p>
        @Model.Name isimli ürünü silmek istiyor musunuz?
        
<form asp-action="Delete" asp-route-id="@Model.ProductId" method="post">
            <input type="hidden" asp-for="@Model.ProductId">
            <button type="submit" class="btn btn-danger">Evet</button>
            <a href="/" class="btn btn-primary">Hayır</a>
        </form>
        
    </p>
</div>